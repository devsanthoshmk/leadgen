# LinkedIn credentials
LINKEDIN_SESSION_PATH=./linkedin_scraper/linkedin_session.json
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# NVIDIA NIM API (for ScrapeGraphAI + AI keyword suggestion)
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=moonshotai/kimi-k2-instruct

# Scraping settings
HEADLESS=true
REQUEST_DELAY=3.0
GOOGLE_SEARCH_MAX_PAGES=3
FUZZY_MATCH_THRESHOLD=85
